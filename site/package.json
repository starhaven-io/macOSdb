{
  "name": "macosdb.com",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check:headers": "node scripts/check-security-headers.mjs",
    "prebuild": "node scripts/check-security-headers.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler deploy --config dist/server/wrangler.json",
    "deploy:dry": "npm run deploy -- --dry-run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/compiler-rs": "^0.3.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/inter": "^5.2.8",
    "astro": "^7.0.7",
    "astro-pagefind": "^2.0.1",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.107.1"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "astro-pagefind": {
      "astro": "$astro"
    }
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true,
    "sharp": true,
    "workerd": true
  }
}
