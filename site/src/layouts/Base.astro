---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Search from 'astro-pagefind/components/Search';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A catalog of open-source components in every macOS release since macOS 11 Big Sur.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="macOSdb" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    {ogImageURL && <meta property="og:image:width" content="1200" />}
    {ogImageURL && <meta property="og:image:height" content="630" />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="64x64" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title" transition:name="site-title">macOSdb</a>
        <div class="nav-links">
          <a href="/components/">Components</a>
          <a href="/compare/">Compare</a>
          <div class="search-wrapper">
            <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false, resetStyles: false }} />
          </div>
          <a href="https://github.com/p-linnane/macOSdb" class="github-link" aria-label="GitHub repository">
            <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
        </div>
      </nav>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer>
      <p>
        Data licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY-4.0</a>. Code licensed under <a
          href="https://www.gnu.org/licenses/gpl-3.0.html">GPL-3.0</a
        >.
      </p>
    </footer>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 2rem;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links a {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .search-wrapper {
    position: relative;
  }

  .search-wrapper :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.7;
    --pagefind-ui-primary: var(--color-link);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-system);
  }

  .search-wrapper :global(.pagefind-ui__form) {
    position: static;
  }

  .search-wrapper :global(.pagefind-ui__search-input) {
    color: var(--color-text);
    position: relative;
    font-family: var(--font-system);
    font-weight: 400;
  }

  .search-wrapper :global(.pagefind-ui__search-input::placeholder) {
    color: var(--color-text-secondary);
    opacity: 1;
  }

  .search-wrapper :global(.pagefind-ui__search-clear) {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    background: transparent;
    color: var(--color-text-secondary);
    border: none;
    cursor: pointer;
    font-size: 0;
    width: 20px;
    height: 20px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-wrapper :global(.pagefind-ui__search-clear::before) {
    content: '✕';
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .search-wrapper :global(.pagefind-ui__search-clear:hover::before) {
    color: var(--color-text);
  }

  .search-wrapper :global(.pagefind-ui__drawer) {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    width: 500px;
    max-height: 70vh;
    overflow-y: auto;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
    z-index: 100;
    padding: 0.75rem;
    animation: searchDropdown 0.15s ease-out;
  }

  @keyframes searchDropdown {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .github-link {
    display: flex;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .site-title:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    max-width: var(--max-width);
    margin: 4rem auto 0;
  }

  footer p {
    margin-bottom: 0.25rem;
  }

  @media (max-width: 640px) {
    header {
      padding: 0.75rem 1rem;
    }

    nav {
      gap: 0.75rem;
    }

    .nav-links {
      gap: 0.75rem;
    }

    .nav-links a {
      font-size: 0.85rem;
    }

    .search-wrapper :global(.pagefind-ui) {
      --pagefind-ui-scale: 0.6;
    }

    .search-wrapper :global(.pagefind-ui__drawer) {
      position: fixed;
      top: auto;
      right: 0.5rem;
      left: 0.5rem;
      width: auto;
      max-height: 60vh;
      margin-top: 4px;
    }

    main {
      padding: 1.25rem 1rem;
    }

    footer {
      padding: 1.5rem 1rem;
      margin-top: 2rem;
    }
  }
</style>
