---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A catalog of open-source components in every macOS release since macOS 11 Big Sur.' } =
  Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title">macOSdb</a>
        <div class="nav-links">
          <a href="/compare/">Compare</a>
          <a href="https://github.com/p-linnane/macOSdb" class="github-link" aria-label="GitHub repository">
            <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        Data licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY-4.0</a>. Code licensed under <a
          href="https://www.gnu.org/licenses/gpl-3.0.html">GPL-3.0</a
        >.
      </p>
    </footer>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 2rem;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links a {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .github-link {
    display: flex;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .site-title:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    max-width: var(--max-width);
    margin: 4rem auto 0;
  }

  footer p {
    margin-bottom: 0.25rem;
  }
</style>
