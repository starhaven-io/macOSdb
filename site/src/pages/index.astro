---
import Base from '../layouts/Base.astro';
import Badge from '../components/Badge.astro';
import StructuredData from '../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { formatDate, displayName, releaseSlug } from '../lib/utils';

const releases = await getCollection('macosReleases');

// Group by major version, derive release names from the data
const grouped: Record<string, typeof releases> = {};
const releaseNames: Record<string, string> = {};
for (const entry of releases) {
  const major = entry.data.osVersion.split('.')[0];
  if (!grouped[major]) grouped[major] = [];
  grouped[major].push(entry);
  if (entry.data.releaseName) releaseNames[major] = entry.data.releaseName;
}

// Sort major versions descending
const majorVersions = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'macOSdb',
  url: 'https://macosdb.com',
  description: 'A catalog of open-source components in every macOS release since macOS 11 Big Sur.',
};
---

<Base title="macOSdb — macOS Component Database">
  <StructuredData slot="head" data={websiteSchema} />

  <div class="hero">
    <h1>macOSdb</h1>
    <p>A catalog of open-source components in every macOS release since macOS 11 Big Sur.</p>
  </div>

  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="release">Release</button>
    <button class="filter-btn" data-filter="beta">Beta</button>
    <button class="filter-btn" data-filter="rc">RC</button>
  </div>

  {
    majorVersions.map((major) => (
      <section class="version-group">
        <h2>
          macOS {major} {releaseNames[major] || ''}
        </h2>
        <div class="table-wrapper">
          <table>
            <colgroup>
              <col style="width: 30%" />
              <col style="width: 18%" />
              <col style="width: 22%" />
              <col style="width: 30%" />
            </colgroup>
            <thead>
              <tr>
                <th>Release</th>
                <th>Build</th>
                <th>Date</th>
                <th>Type</th>
              </tr>
            </thead>
            <tbody>
              {grouped[major].map((entry) => (
                <tr data-type={entry.data.isBeta ? 'beta' : entry.data.isRC ? 'rc' : 'release'}>
                  <td>
                    <a href={`/release/${releaseSlug(entry.data)}/`}>{displayName(entry.data)}</a>
                  </td>
                  <td>
                    <code>{entry.data.buildNumber}</code>
                  </td>
                  <td>{formatDate(entry.data.releaseDate)}</td>
                  <td>
                    {entry.data.isBeta ? (
                      <Badge variant="beta" />
                    ) : entry.data.isRC ? (
                      <Badge variant="rc" />
                    ) : (
                      <Badge variant="release" />
                    )}
                    {entry.data.isDeviceSpecific && <Badge variant="device" />}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  }
</Base>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
  }

  .version-group {
    margin-bottom: 3rem;
  }

  .version-group h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .version-group .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .version-group table {
    table-layout: fixed;
    min-width: 500px;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    font-family: var(--font-system);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.35em 0.9em;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    user-select: none;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .filter-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .filter-btn.active {
    background: var(--color-link);
    color: #fff;
    border-color: var(--color-link);
  }

  tr.filtered {
    display: none;
  }
</style>

<script>
  function init() {
    const key = 'macosdb-type-filter';
    const buttons = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
    const rows = document.querySelectorAll('tr[data-type]') as NodeListOf<HTMLTableRowElement>;

    if (!buttons.length) return;

    function apply(filter: string) {
      rows.forEach((row) => {
        row.classList.toggle('filtered', filter !== 'all' && row.dataset.type !== filter);
      });
      buttons.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.filter === filter);
      });
    }

    const saved = localStorage.getItem(key) || 'all';
    apply(saved);

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter!;
        localStorage.setItem(key, filter);
        apply(filter);
      });
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
