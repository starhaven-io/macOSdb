---
import Base from '../layouts/Base.astro';
import StructuredData from '../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { formatDate, displayName, releaseSlug } from '../lib/utils';

const macosReleases = (await getCollection('macosReleases')).sort(
  (a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime(),
);
const xcodeReleases = (await getCollection('xcodeReleases')).sort(
  (a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime(),
);

const latestMacos = macosReleases.find((r) => !r.data.isBeta && !r.data.isRC);
const latestXcode = xcodeReleases.find((r) => !r.data.isBeta && !r.data.isRC);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'macOSdb',
  url: 'https://macosdb.com',
  description: 'A catalog of open-source components across macOS and Xcode releases for Apple silicon.',
};
---

<Base title="macOSdb — Apple Platform Component Database">
  <StructuredData slot="head" data={websiteSchema} />

  <div class="hero">
    <h1>macOSdb</h1>
    <p>A catalog of open-source components across macOS and Xcode releases for Apple silicon.</p>
  </div>

  <div class="product-grid">
    <div class="product-card">
      <h2><a href="/macos/">macOS</a></h2>
      <p class="product-desc">
        {macosReleases.length} releases tracked since macOS 11 Big Sur.
      </p>
      {
        latestMacos && (
          <div class="latest">
            <span class="latest-label">Latest</span>
            <a href={`/macos/release/${releaseSlug(latestMacos.data)}/`}>{displayName(latestMacos.data, true)}</a>
            <span class="latest-date">{formatDate(latestMacos.data.releaseDate)}</span>
          </div>
        )
      }
      <div class="product-links">
        <a href="/macos/releases/">Releases</a>
        <a href="/macos/components/">Components</a>
        <a href="/macos/compare/">Compare</a>
      </div>
    </div>

    <div class="product-card">
      <h2><a href="/xcode/">Xcode</a></h2>
      <p class="product-desc">
        {xcodeReleases.length} releases tracked since Xcode 12.
      </p>
      {
        latestXcode && (
          <div class="latest">
            <span class="latest-label">Latest</span>
            <a href={`/xcode/release/${releaseSlug(latestXcode.data)}/`}>
              {displayName(latestXcode.data, false, 'Xcode')}
            </a>
            <span class="latest-date">{formatDate(latestXcode.data.releaseDate)}</span>
          </div>
        )
      }
      <div class="product-links">
        <a href="/xcode/releases/">Releases</a>
        <a href="/xcode/components/">Components</a>
        <a href="/xcode/compare/">Compare</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
  }

  .product-card h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .product-card h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .product-card h2 a:hover {
    color: var(--color-link);
  }

  .product-desc {
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .latest {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
    flex-wrap: wrap;
  }

  .latest-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
  }

  .latest-date {
    color: var(--color-text-secondary);
  }

  .product-links {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
