---
import ProductComponentDetail from '../../../components/ProductComponentDetail.astro';
import { products } from '../../../lib/products';
import { getComponentHistory, getAllComponentSlugs } from '../../../lib/api';

export async function getStaticPaths() {
  const slugs = await getAllComponentSlugs('macos');
  const paths = await Promise.all(
    slugs.map(async (slug) => {
      const history = await getComponentHistory('macos', slug);
      return {
        params: { name: slug },
        props: {
          componentName: history!.name,
          source: history!.source,
          path: history!.path,
          changes: history!.changes,
        },
      };
    }),
  );
  return paths;
}

const { componentName, source, path, changes } = Astro.props;
---

<ProductComponentDetail
  product={products.macos}
  componentName={componentName}
  source={source}
  path={path}
  changes={changes}
/>
