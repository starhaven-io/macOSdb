---
import Base from '../../../layouts/Base.astro';
import ReleaseHeader from '../../../components/ReleaseHeader.astro';
import ComponentTable from '../../../components/ComponentTable.astro';
import KernelInfo from '../../../components/KernelInfo.astro';
import ChipGrid from '../../../components/ChipGrid.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { displayName, releaseSlug } from '../../../lib/utils';

export async function getStaticPaths() {
  const allReleases = await getCollection('macosReleaseDetails');
  const releases = allReleases.sort(
    (a, b) => new Date(b.data.releaseDate ?? '').getTime() - new Date(a.data.releaseDate ?? '').getTime(),
  );

  return releases.map((entry, i) => {
    const prev = i < releases.length - 1 ? releases[i + 1] : null;
    const previousSlug = prev ? releaseSlug(prev.data) : null;
    return {
      params: { slug: `${entry.data.osVersion}-${entry.data.buildNumber}` },
      props: { release: entry.data, previousSlug },
    };
  });
}

interface Props {
  release: {
    buildNumber: string;
    osVersion: string;
    releaseName: string;
    releaseDate?: string;
    isBeta: boolean;
    isRC: boolean;
    isDeviceSpecific?: boolean;
    betaNumber?: number;
    rcNumber?: number;
    ipswURL?: string;
    components: { name: string; version?: string | null; path: string; source: string }[];
    kernels: {
      darwinVersion: string;
      xnuVersion?: string | null;
      arch: string;
      chip: string;
      file: string;
      deviceChips?: { device: string; chip: string }[];
    }[];
  };
  previousSlug: string | null;
}

const { release, previousSlug } = Astro.props;
const currentSlug = releaseSlug(release);
const title = displayName(release, true);

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: title,
    operatingSystem: 'macOS',
    applicationCategory: 'OperatingSystem',
    softwareVersion: release.osVersion,
    ...(release.releaseDate && { datePublished: release.releaseDate }),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'macOSdb', item: 'https://macosdb.com/' },
      { '@type': 'ListItem', position: 2, name: 'macOS', item: 'https://macosdb.com/macos/' },
      { '@type': 'ListItem', position: 3, name: title, item: `https://macosdb.com/macos/release/${currentSlug}/` },
    ],
  },
];
---

<Base
  title={`${title} — macOSdb`}
  description={`Components and hardware support for ${title}`}
  ogImage={`/macos/og/${currentSlug}.png`}
>
  <StructuredData slot="head" data={structuredData} />

  <nav class="breadcrumb" data-pagefind-ignore>
    <a href="/">macOSdb</a> &rsaquo; <a href="/macos/">macOS</a> &rsaquo; {title}
  </nav>

  <ReleaseHeader
    title={title}
    buildNumber={release.buildNumber}
    releaseDate={release.releaseDate}
    isBeta={release.isBeta}
    isRC={release.isRC}
    isDeviceSpecific={release.isDeviceSpecific}
  >
    {release.ipswURL && <a href={release.ipswURL}>Download IPSW</a>}
    {previousSlug && <a href={`/macos/compare/?from=${previousSlug}&to=${currentSlug}`}>Compare with previous</a>}
  </ReleaseHeader>

  <ComponentTable components={release.components} basePath="/macos" />
  <KernelInfo kernels={release.kernels} />
  <ChipGrid kernels={release.kernels} />
</Base>

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  section h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
</style>
