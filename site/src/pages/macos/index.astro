---
import Base from '../../layouts/Base.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { formatDate, displayName, releaseSlug } from '../../lib/utils';

const allReleases = (await getCollection('macosReleases')).sort(
  (a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime(),
);

const latest = allReleases.find((r) => !r.data.isBeta && !r.data.isRC);
const totalReleases = allReleases.length;
const gaReleases = allReleases.filter((r) => !r.data.isBeta && !r.data.isRC).length;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'macOS Release Database',
  url: 'https://macosdb.com/macos/',
  description: 'A catalog of open-source components across macOS releases for Apple silicon.',
};
---

<Base title="macOS — macOSdb" description="Open-source components tracked across macOS releases for Apple silicon.">
  <StructuredData slot="head" data={structuredData} />

  <nav class="breadcrumb" data-pagefind-ignore>
    <a href="/">macOSdb</a> &rsaquo; macOS
  </nav>

  <div class="hero">
    <h1>macOS</h1>
    <p>Open-source components tracked across macOS releases for Apple silicon.</p>
  </div>

  {
    latest && (
      <div class="latest-release">
        <span class="latest-label">Latest release</span>
        <a href={`/macos/release/${releaseSlug(latest.data)}/`} class="latest-name">
          {displayName(latest.data, true)}
        </a>
        <span class="latest-date">{formatDate(latest.data.releaseDate, 'long')}</span>
      </div>
    )
  }

  <div class="stats">
    <span>{totalReleases} releases tracked</span>
    <span>{gaReleases} GA releases</span>
  </div>

  <div class="section-grid">
    <a href="/macos/releases/" class="section-card">
      <h2>Releases</h2>
      <p>Browse all {totalReleases} macOS releases since macOS 11 Big Sur.</p>
    </a>

    <a href="/macos/components/" class="section-card">
      <h2>Components</h2>
      <p>View open-source components and their version history across releases.</p>
    </a>

    <a href="/macos/compare/" class="section-card">
      <h2>Compare</h2>
      <p>Compare component versions between any two macOS releases side by side.</p>
    </a>
  </div>
</Base>

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .hero {
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
  }

  .latest-release {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    flex-wrap: wrap;
  }

  .latest-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
  }

  .latest-name {
    font-weight: 600;
  }

  .latest-date {
    color: var(--color-text-secondary);
  }

  .stats {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .section-card {
    display: block;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition:
      box-shadow 0.2s,
      transform 0.2s,
      border-color 0.2s;
  }

  .section-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-1px);
    border-color: var(--color-link);
    text-decoration: none;
    color: var(--color-text);
  }

  .section-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-card p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .section-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
