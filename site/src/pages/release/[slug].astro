---
import Base from '../../layouts/Base.astro';
import Badge from '../../components/Badge.astro';
import ComponentTable from '../../components/ComponentTable.astro';
import KernelInfo from '../../components/KernelInfo.astro';
import ChipGrid from '../../components/ChipGrid.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { formatDate, displayName, releaseSlug } from '../../lib/utils';

export async function getStaticPaths() {
  const allReleases = await getCollection('macosReleaseDetails');
  const releases = allReleases.sort(
    (a, b) => new Date(b.data.releaseDate ?? '').getTime() - new Date(a.data.releaseDate ?? '').getTime(),
  );

  return releases.map((entry, i) => {
    const prev = i < releases.length - 1 ? releases[i + 1] : null;
    const previousSlug = prev ? releaseSlug(prev.data) : null;
    return {
      params: { slug: `${entry.data.osVersion}-${entry.data.buildNumber}` },
      props: { release: entry.data, previousSlug },
    };
  });
}

interface Props {
  release: {
    buildNumber: string;
    osVersion: string;
    releaseName: string;
    releaseDate?: string;
    isBeta: boolean;
    isRC: boolean;
    isDeviceSpecific?: boolean;
    betaNumber?: number;
    rcNumber?: number;
    ipswURL?: string;
    components: { name: string; version?: string | null; path: string; source: string }[];
    kernels: {
      darwinVersion: string;
      xnuVersion?: string | null;
      deviceChips?: { device: string; chip: string }[];
    }[];
  };
  previousSlug: string | null;
}

const { release, previousSlug } = Astro.props;
const currentSlug = releaseSlug(release);
const title = displayName(release, true);
const darwinVersion = release.kernels?.[0]?.darwinVersion;
const xnuVersion = release.kernels?.[0]?.xnuVersion;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: title,
    operatingSystem: 'macOS',
    applicationCategory: 'OperatingSystem',
    softwareVersion: release.osVersion,
    ...(release.releaseDate && { datePublished: release.releaseDate }),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'macOSdb',
        item: 'https://macosdb.com/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: `https://macosdb.com/release/${currentSlug}/`,
      },
    ],
  },
];
---

<Base
  title={`${title} — macOSdb`}
  description={`Components and hardware support for ${title}`}
  ogImage={`/og/${currentSlug}.png`}
>
  <StructuredData slot="head" data={structuredData} />

  <nav class="breadcrumb">
    <a href="/">macOSdb</a> &rsaquo; {title}
  </nav>

  <header class="release-header">
    <h1>{title}</h1>
    <div class="meta">
      <span>Build <code>{release.buildNumber}</code></span>
      {release.releaseDate && <span>{formatDate(release.releaseDate, 'long')}</span>}
      {release.isBeta && <Badge variant="beta" />}
      {release.isRC && <Badge variant="rc" />}
      {release.isDeviceSpecific && <Badge variant="device" />}
      {
        release.ipswURL && (
          <a href={release.ipswURL} class="ipsw-link">
            Download IPSW
          </a>
        )
      }
      {
        previousSlug && (
          <a href={`/compare/?from=${previousSlug}&to=${currentSlug}`} class="compare-link">
            Compare with previous
          </a>
        )
      }
    </div>
  </header>

  <KernelInfo darwinVersion={darwinVersion} xnuVersion={xnuVersion} />
  <ComponentTable components={release.components} />
  <ChipGrid kernels={release.kernels} />
</Base>

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .release-header {
    margin-bottom: 2.5rem;
  }

  .release-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .meta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    color: var(--color-text-secondary);
  }

  .ipsw-link,
  .compare-link {
    font-size: 0.85rem;
    color: var(--color-link);
  }

  section h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
</style>
