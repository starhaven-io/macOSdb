---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { displayName } from '../lib/utils';

const allReleases = await getCollection('macosReleases');
const releases = allReleases.sort(
  (a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime(),
);

// Build a lookup from slug to API path for client-side fetching
const releaseOptions = releases.map((entry) => ({
  key: `${entry.data.osVersion}-${entry.data.buildNumber}`,
  label: `${displayName(entry.data)} (${entry.data.buildNumber})`,
  apiPath: entry.data.dataFile.replace(/^releases\//, '').replace(/\.json$/, ''),
}));
---

<Base title="Compare Releases — macOSdb">
  <h1>Compare Releases</h1>
  <p class="subtitle">Select two macOS releases to compare their open-source components.</p>

  <div class="controls">
    <div class="select-group">
      <label for="from-select">From</label>
      <select id="from-select">
        <option value="">Select a release…</option>
        {
          releaseOptions.map((opt) => (
            <option value={opt.key} data-api={opt.apiPath}>
              {opt.label}
            </option>
          ))
        }
      </select>
    </div>
    <span class="arrow">&rarr;</span>
    <div class="select-group">
      <label for="to-select">To</label>
      <select id="to-select">
        <option value="">Select a release…</option>
        {
          releaseOptions.map((opt) => (
            <option value={opt.key} data-api={opt.apiPath}>
              {opt.label}
            </option>
          ))
        }
      </select>
    </div>
    <button id="compare-btn" type="button">Compare</button>
  </div>

  <div id="results" class="results hidden">
    <div id="summary" class="summary"></div>

    <div class="filter-bar">
      <label>
        <input type="checkbox" id="changed-only" checked />
        Show changed only
      </label>
    </div>

    <table>
      <thead>
        <tr>
          <th>Component</th>
          <th>From</th>
          <th>To</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="comparison-body"></tbody>
    </table>

    <div id="added-section" class="diff-section hidden">
      <h3>Added</h3>
      <table>
        <thead>
          <tr>
            <th>Component</th>
            <th>Version</th>
          </tr>
        </thead>
        <tbody id="added-body"></tbody>
      </table>
    </div>

    <div id="removed-section" class="diff-section hidden">
      <h3>Removed</h3>
      <table>
        <thead>
          <tr>
            <th>Component</th>
            <th>Version</th>
          </tr>
        </thead>
        <tbody id="removed-body"></tbody>
      </table>
    </div>
  </div>
</Base>

<script>
  // Client-side cache for fetched release data (persists across navigations)
  const releaseCache = new Map<string, any[]>();

  function initCompare() {
    const fromSelect = document.getElementById('from-select') as HTMLSelectElement;
    const toSelect = document.getElementById('to-select') as HTMLSelectElement;
    const compareBtn = document.getElementById('compare-btn') as HTMLButtonElement;
    const changedOnly = document.getElementById('changed-only') as HTMLInputElement;
    const results = document.getElementById('results')!;
    const summary = document.getElementById('summary')!;
    const comparisonBody = document.getElementById('comparison-body')!;
    const addedSection = document.getElementById('added-section')!;
    const addedBody = document.getElementById('added-body')!;
    const removedSection = document.getElementById('removed-section')!;
    const removedBody = document.getElementById('removed-body')!;

    if (!fromSelect) return;

    async function fetchComponents(select: HTMLSelectElement): Promise<any[]> {
      const key = select.value;
      if (releaseCache.has(key)) return releaseCache.get(key)!;

      const option = select.selectedOptions[0];
      const apiPath = option?.dataset.api;
      if (!apiPath) return [];

      const response = await fetch(`/api/v1/macos/releases/${apiPath}.json`);
      if (!response.ok) return [];

      const data = await response.json();
      releaseCache.set(key, data.components);
      return data.components;
    }

    function parseVersion(version: string): number[] {
      const cleaned = version.replace(/\s*\(.*\)/, '').trim();
      return cleaned.split('.').flatMap((segment) => {
        return segment
          .split(/[^0-9]+/)
          .filter(Boolean)
          .map(Number);
      });
    }

    function compareVersions(from: string, to: string): 'upgraded' | 'downgraded' | 'unchanged' {
      const fromParts = parseVersion(from);
      const toParts = parseVersion(to);
      const maxLen = Math.max(fromParts.length, toParts.length);

      for (let i = 0; i < maxLen; i++) {
        const f = i < fromParts.length ? fromParts[i] : 0;
        const t = i < toParts.length ? toParts[i] : 0;
        if (f < t) return 'upgraded';
        if (f > t) return 'downgraded';
      }
      return 'unchanged';
    }

    function updateURL() {
      const params = new URLSearchParams();
      if (fromSelect.value) params.set('from', fromSelect.value);
      if (toSelect.value) params.set('to', toSelect.value);
      const url = `${window.location.pathname}?${params.toString()}`;
      history.replaceState(null, '', url);
    }

    async function runComparison() {
      const fromKey = fromSelect.value;
      const toKey = toSelect.value;
      if (!fromKey || !toKey) return;

      updateURL();
      compareBtn.textContent = 'Loading…';
      compareBtn.disabled = true;

      try {
        const [fromComponents, toComponents] = await Promise.all([
          fetchComponents(fromSelect),
          fetchComponents(toSelect),
        ]);

        const fromMap = new Map(fromComponents.map((c: any) => [c.name, c]));
        const toMap = new Map(toComponents.map((c: any) => [c.name, c]));
        const allNames = [...new Set([...fromMap.keys(), ...toMap.keys()])].sort();

        const changes: { name: string; from: string; to: string; direction: string }[] = [];
        const added: { name: string; version: string }[] = [];
        const removed: { name: string; version: string }[] = [];

        for (const name of allNames) {
          const fromComp = fromMap.get(name);
          const toComp = toMap.get(name);

          if (fromComp && toComp) {
            const fromVer = fromComp.version || '';
            const toVer = toComp.version || '';
            changes.push({ name, from: fromVer, to: toVer, direction: compareVersions(fromVer, toVer) });
          } else if (!fromComp && toComp) {
            added.push({ name, version: toComp.version || '' });
          } else if (fromComp && !toComp) {
            removed.push({ name, version: fromComp.version || '' });
          }
        }

        const upgraded = changes.filter((c) => c.direction === 'upgraded').length;
        const downgraded = changes.filter((c) => c.direction === 'downgraded').length;

        const hasChanges = upgraded > 0 || downgraded > 0 || added.length > 0 || removed.length > 0;

        if (!hasChanges) {
          summary.innerHTML = '<span class="no-changes">No differences found between these releases.</span>';
          comparisonBody.innerHTML = '';
          addedSection.classList.add('hidden');
          removedSection.classList.add('hidden');
          results.classList.remove('hidden');
          (window as any).__compareChanges = changes;
          return;
        }

        summary.innerHTML = [
          upgraded > 0 ? `<span class="badge badge-upgraded">${upgraded} upgraded</span>` : '',
          downgraded > 0 ? `<span class="badge badge-downgraded">${downgraded} downgraded</span>` : '',
          added.length > 0 ? `<span class="badge badge-added">${added.length} added</span>` : '',
          removed.length > 0 ? `<span class="badge badge-removed">${removed.length} removed</span>` : '',
        ]
          .filter(Boolean)
          .join(' ');

        renderTable(changes);

        if (added.length > 0) {
          addedSection.classList.remove('hidden');
          addedBody.innerHTML = added
            .map((c) => `<tr><td>${c.name}</td><td><code>${c.version}</code></td></tr>`)
            .join('');
        } else {
          addedSection.classList.add('hidden');
        }

        if (removed.length > 0) {
          removedSection.classList.remove('hidden');
          removedBody.innerHTML = removed
            .map((c) => `<tr><td>${c.name}</td><td><code>${c.version}</code></td></tr>`)
            .join('');
        } else {
          removedSection.classList.add('hidden');
        }

        results.classList.remove('hidden');
        (window as any).__compareChanges = changes;
      } finally {
        compareBtn.textContent = 'Compare';
        compareBtn.disabled = false;
      }
    }

    function renderTable(changes: { name: string; from: string; to: string; direction: string }[]) {
      const showChangedOnly = changedOnly.checked;
      const filtered = showChangedOnly ? changes.filter((c) => c.direction !== 'unchanged') : changes;

      comparisonBody.innerHTML = filtered
        .map((c) => {
          const statusClass = `status-${c.direction}`;
          const statusLabel =
            c.direction === 'upgraded' ? '↑ Upgraded' : c.direction === 'downgraded' ? '↓ Downgraded' : '— Unchanged';
          return `<tr class="${statusClass}">
        <td>${c.name}</td>
        <td><code>${c.from}</code></td>
        <td><code>${c.to}</code></td>
        <td><span class="status-badge ${statusClass}">${statusLabel}</span></td>
      </tr>`;
        })
        .join('');
    }

    compareBtn.addEventListener('click', runComparison);
    changedOnly.addEventListener('change', () => {
      const changes = (window as any).__compareChanges;
      if (changes) renderTable(changes);
    });

    // Apply URL params if present, otherwise use defaults
    const params = new URLSearchParams(window.location.search);
    const paramFrom = params.get('from');
    const paramTo = params.get('to');
    if (paramFrom) fromSelect.value = paramFrom;
    if (paramTo) toSelect.value = paramTo;

    if (fromSelect.value && toSelect.value) {
      runComparison();
    }
  }

  document.addEventListener('astro:page-load', initCompare);
</script>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .controls {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .select-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 200px;
  }

  .select-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  select {
    font-family: var(--font-system);
    font-size: 0.95rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text);
    width: 100%;
  }

  .arrow {
    font-size: 1.5rem;
    color: var(--color-text-secondary);
    padding-bottom: 0.25rem;
  }

  button {
    font-family: var(--font-system);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    border: none;
    border-radius: 6px;
    background: var(--color-link);
    color: #fff;
    cursor: pointer;
  }

  button:hover {
    background: var(--color-link-hover);
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .hidden {
    display: none;
  }

  .summary {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .badge {
    display: inline-block;
    padding: 0.25em 0.75em;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .badge-upgraded {
    background: color-mix(in srgb, var(--color-upgraded) 15%, transparent);
    color: var(--color-upgraded);
  }

  .badge-downgraded {
    background: color-mix(in srgb, var(--color-downgraded) 15%, transparent);
    color: var(--color-downgraded);
  }

  .badge-added {
    background: color-mix(in srgb, var(--color-added) 15%, transparent);
    color: var(--color-added);
  }

  .badge-removed {
    background: color-mix(in srgb, var(--color-removed) 15%, transparent);
    color: var(--color-removed);
  }

  .filter-bar {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .filter-bar label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    color: var(--color-text-secondary);
  }

  .status-badge {
    display: inline-block;
    padding: 0.15em 0.5em;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .status-upgraded .status-badge {
    color: var(--color-upgraded);
  }

  .status-downgraded .status-badge {
    color: var(--color-downgraded);
  }

  .status-unchanged .status-badge {
    color: var(--color-text-secondary);
  }

  .diff-section {
    margin-top: 2rem;
  }

  .diff-section h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  #added-section h3 {
    color: var(--color-added);
  }

  #removed-section h3 {
    color: var(--color-removed);
  }

  .results {
    margin-top: 2rem;
  }

  .no-changes {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
  }
</style>
