---
interface Component {
  name: string;
  version?: string | null;
  path: string;
  source: string;
}

interface Props {
  components: Component[];
}

const { components } = Astro.props;
const sorted = [...components].sort((a, b) => a.name.localeCompare(b.name));
---

<section class="components">
  <h2>Components</h2>
  <table>
    <thead>
      <tr>
        <th>Component</th>
        <th>Version</th>
        <th>Source</th>
        <th>Path</th>
      </tr>
    </thead>
    <tbody>
      {
        sorted.map((comp) => (
          <tr>
            <td class="comp-name">{comp.name}</td>
            <td>
              <code>{comp.version}</code>
            </td>
            <td data-pagefind-ignore>
              <span class:list={['source', `source-${comp.source}`]}>
                {comp.source === 'dyldCache' ? 'dyld cache' : comp.source}
              </span>
            </td>
            <td class="comp-path" data-pagefind-ignore>
              <code>{comp.path}</code>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</section>

<style>
  .components {
    margin-bottom: 2.5rem;
  }

  .comp-name {
    font-weight: 500;
  }

  .comp-path code {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .source {
    font-size: 0.8rem;
    padding: 0.15em 0.5em;
    border-radius: 4px;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
  }
</style>
