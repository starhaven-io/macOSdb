---
import Base from '../layouts/Base.astro';
import Badge from './Badge.astro';
import StructuredData from './StructuredData.astro';
import { getCollection } from 'astro:content';
import { formatDate, displayName, releaseSlug } from '../lib/utils';
import type { ProductConfig } from '../lib/products';

interface Props {
  product: ProductConfig;
}

const { product } = Astro.props;
const allReleases = await getCollection(product.indexCollection);

const releases = allReleases.sort(
  (a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime(),
);

const isXcode = product.key === 'xcode';
const minMacOSByID = new Map<string, string>();
const sdkByID = new Map<string, string>();
if (isXcode) {
  const details = await getCollection('xcodeReleaseDetails');
  for (const entry of details) {
    if (entry.data.minimumOSVersion) {
      minMacOSByID.set(entry.id, entry.data.minimumOSVersion);
    }
    const sdk = entry.data.sdks?.[0]?.sdkVersion;
    if (sdk) sdkByID.set(entry.id, sdk);
  }
}

const grouped: Record<string, typeof releases> = {};
const releaseNames: Record<string, string> = {};
for (const entry of releases) {
  const major = entry.data.osVersion.split('.')[0];
  if (!grouped[major]) grouped[major] = [];
  grouped[major].push(entry);
  if (product.includeReleaseName && entry.data.releaseName) {
    releaseNames[major] = entry.data.releaseName;
  }
}

const majorVersions = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${product.label} Release Database`,
  url: `https://macosdb.com/${product.key}/`,
  description: `A catalog of open-source components across ${product.label} releases for Apple silicon.`,
};
---

<Base
  title={`${product.label} Releases — macOSdb`}
  description={`Open-source components tracked across ${product.label} releases for Apple silicon.`}
>
  <StructuredData slot="head" data={structuredData} />

  <nav class="breadcrumb" data-pagefind-ignore>
    <a href="/">macOSdb</a> &rsaquo; <a href={`/${product.key}/`}>{product.label}</a> &rsaquo; Releases
  </nav>

  <div class="hero">
    <h1>{product.label} Releases</h1>
    <p>Open-source components tracked across {product.label} releases for Apple silicon.</p>
    <div class="section-nav" data-pagefind-ignore>
      <a href={`/${product.key}/components/`}>Components</a>
      <a href={`/${product.key}/compare/`}>Compare</a>
    </div>
  </div>

  <div class="filter-bar" role="group" aria-label="Filter releases by type">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="release">Release</button>
    <button class="filter-btn" data-filter="beta">Beta</button>
    <button class="filter-btn" data-filter="rc">RC</button>
  </div>

  {
    majorVersions.map((major) => (
      <section class="version-group">
        <h2>
          {product.label} {major} {releaseNames[major] || ''}
        </h2>
        <div class="table-wrapper">
          <table class="js-stripe">
            <colgroup>
              {isXcode ? (
                <>
                  <col style="width: 22%" />
                  <col style="width: 14%" />
                  <col style="width: 18%" />
                  <col style="width: 14%" />
                  <col style="width: 10%" />
                  <col style="width: 22%" />
                </>
              ) : (
                <>
                  <col style="width: 30%" />
                  <col style="width: 18%" />
                  <col style="width: 22%" />
                  <col style="width: 30%" />
                </>
              )}
            </colgroup>
            <thead>
              <tr>
                <th>Release</th>
                <th>Build</th>
                <th>Date</th>
                {isXcode && <th>Min macOS</th>}
                {isXcode && <th>SDK</th>}
                <th>Type</th>
              </tr>
            </thead>
            <tbody>
              {grouped[major].map((entry) => (
                <tr data-type={entry.data.isBeta ? 'beta' : entry.data.isRC ? 'rc' : 'release'}>
                  <td>
                    <a href={`/${product.key}/release/${releaseSlug(entry.data)}/`}>
                      {displayName(entry.data, product.includeReleaseName, product.label)}
                    </a>
                  </td>
                  <td>
                    <code>{entry.data.buildNumber}</code>
                  </td>
                  <td>{formatDate(entry.data.releaseDate)}</td>
                  {isXcode && <td class="min-macos">{minMacOSByID.get(entry.id) ?? '—'}</td>}
                  {isXcode && <td class="sdk-version">{sdkByID.get(entry.id) ?? '—'}</td>}
                  <td>
                    <div class="type-cell">
                      {entry.data.isBeta ? (
                        <Badge variant="beta" />
                      ) : entry.data.isRC ? (
                        <Badge variant="rc" />
                      ) : (
                        <Badge variant="release" />
                      )}
                      {'isDeviceSpecific' in entry.data && entry.data.isDeviceSpecific && <Badge variant="device" />}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  }
</Base>

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
  }

  .section-nav {
    display: flex;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .section-nav a {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .version-group {
    margin-bottom: 3rem;
  }

  .version-group h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .version-group .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .version-group table {
    table-layout: fixed;
    min-width: 500px;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    font-family: var(--font-system);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.35em 0.9em;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    user-select: none;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .filter-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .filter-btn.active {
    background: var(--color-link);
    color: #fff;
    border-color: var(--color-link);
  }

  .type-cell {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    align-items: center;
  }

  .min-macos,
  .sdk-version {
    font-variant-numeric: tabular-nums;
    color: var(--color-text-secondary);
  }

  tr.filtered {
    display: none;
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .version-group {
      margin-bottom: 2rem;
    }

    .version-group h2 {
      font-size: 1.25rem;
    }

    .version-group table {
      min-width: 400px;
    }
  }
</style>

<script>
  function init() {
    const product = window.location.pathname.split('/')[1] || 'releases';
    const key = `macosdb-${product}-type-filter`;
    const buttons = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
    const rows = document.querySelectorAll('tr[data-type]') as NodeListOf<HTMLTableRowElement>;

    if (!buttons.length) return;

    function apply(filter: string) {
      rows.forEach((row) => {
        row.classList.toggle('filtered', filter !== 'all' && row.dataset.type !== filter);
      });
      buttons.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.filter === filter);
      });
      document.querySelectorAll('tbody').forEach((tbody) => {
        let i = 0;
        tbody.querySelectorAll('tr').forEach((row) => {
          if (!row.classList.contains('filtered')) {
            row.classList.toggle('stripe', i % 2 === 1);
            i++;
          } else {
            row.classList.remove('stripe');
          }
        });
      });
    }

    const saved = localStorage.getItem(key) || 'all';
    apply(saved);

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter!;
        localStorage.setItem(key, filter);
        apply(filter);
      });
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
