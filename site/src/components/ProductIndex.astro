---
import Base from '../layouts/Base.astro';
import StructuredData from './StructuredData.astro';
import { getCollection } from 'astro:content';
import { formatDate, displayName, releaseSlug, compareReleasesByRecency } from '../lib/utils';
import type { ProductConfig } from '../lib/products';

interface Props {
  product: ProductConfig;
}

const { product } = Astro.props;

const allReleases = [...(await getCollection(product.indexCollection))].sort((a, b) =>
  compareReleasesByRecency(a.data, b.data),
);

const latestGA = allReleases.find((r) => !r.data.isBeta && !r.data.isRC) ?? null;
const newestPre = allReleases.find((r) => r.data.isBeta || r.data.isRC) ?? null;
const latestPre =
  newestPre && (!latestGA || compareReleasesByRecency(newestPre.data, latestGA.data) < 0) ? newestPre : null;
const totalReleases = allReleases.length;
const gaReleases = allReleases.filter((r) => !r.data.isBeta && !r.data.isRC).length;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${product.label} Release Database`,
  url: `https://macosdb.com/${product.key}/`,
  description: `A catalog of open-source components across ${product.label} releases for Apple silicon.`,
};
---

<Base
  title={`${product.label} — macOSdb`}
  description={`Open-source components tracked across ${product.label} releases for Apple silicon.`}
>
  <StructuredData slot="head" data={structuredData} />

  <nav class="breadcrumb" data-pagefind-ignore>
    <a href="/">macOSdb</a> &rsaquo; {product.label}
  </nav>

  <div class="hero">
    <h1>{product.label}</h1>
    <p>Open-source components tracked across {product.label} releases for Apple silicon.</p>
  </div>

  {
    latestGA && (
      <div class="latest-release">
        <span class="latest-label">{latestPre ? 'Latest stable' : 'Latest release'}</span>
        <a href={`/${product.key}/release/${releaseSlug(latestGA.data)}/`} class="latest-name">
          {displayName(latestGA.data, product.includeReleaseName, product.label)}
        </a>
        <span class="latest-date">{formatDate(latestGA.data.releaseDate, 'long')}</span>
      </div>
    )
  }
  {
    latestPre && (
      <div class="latest-release">
        <span class="latest-label">{latestPre.data.isBeta ? 'Latest beta' : 'Latest RC'}</span>
        <a href={`/${product.key}/release/${releaseSlug(latestPre.data)}/`} class="latest-name">
          {displayName(latestPre.data, product.includeReleaseName, product.label)}
        </a>
        <span class="latest-date">{formatDate(latestPre.data.releaseDate, 'long')}</span>
      </div>
    )
  }

  <div class="stats">
    <span>{totalReleases} releases tracked</span>
    <span>{gaReleases} GA releases</span>
  </div>

  <div class="section-grid">
    <a href={`/${product.key}/releases/`} class="section-card">
      <h2>Releases</h2>
      <p>Browse all {totalReleases} {product.label} releases since {product.firstRelease}.</p>
    </a>

    <a href={`/${product.key}/components/`} class="section-card">
      <h2>Components</h2>
      <p>View open-source components and their version history across releases.</p>
    </a>

    <a href={`/${product.key}/compare/`} class="section-card">
      <h2>Compare</h2>
      <p>Compare component versions between any two {product.label} releases side by side.</p>
    </a>
  </div>
</Base>

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .hero {
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
  }

  .latest-release {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.15rem 0.6rem;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .latest-label {
    flex-basis: 100%;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
  }

  .latest-name {
    font-weight: 600;
  }

  .latest-date {
    color: var(--color-text-secondary);
  }

  .stats {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .section-card {
    display: block;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition:
      box-shadow 0.2s,
      transform 0.2s,
      border-color 0.2s;
  }

  .section-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-1px);
    border-color: var(--color-link);
    text-decoration: none;
    color: var(--color-text);
  }

  .section-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-card p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .section-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
